{
  "entities": {
    "profile": {
      "title": "Profile",
      "description": "Main portfolio information",
      "type": "object",
      "properties": {
        "personalInfo": { "type": "object" },
        "about": { "type": "object" },
        "skills": { "type": "array" },
        "education": { "type": "array" },
        "certifications": { "type": "array" },
        "profileImage": { "type": "string" },
        "languages": { "type": "array" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["personalInfo", "profileImage"]
    },
    "project": {
      "title": "Project",
      "description": "Portfolio project item",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "tags": { "type": "array" },
        "links": { "type": "object" },
        "order": { "type": "number" }
      },
      "required": ["id", "title", "imageUrl"]
    }
  },
  "firestore": {
    "/portfolio/main": {
      "schema": "profile",
      "description": "The main profile document"
    },
    "/projects/{projectId}": {
      "schema": "project",
      "description": "Individual project items"
    }
  }
}
